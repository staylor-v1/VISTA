# Development Dockerfile for VISTA
# Multi-stage build with separate targets for backend and frontend development

# Backend development stage
FROM python:3.11-bookworm AS backend-dev

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libpq-dev \
    git \
    curl \
    wget \
    ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Create virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Install uv and debugging tools
RUN pip install --no-cache-dir --upgrade pip uv

WORKDIR /app

# Install Python dependencies (cached layer)
COPY requirements.txt .
RUN uv pip install --no-cache-dir -r requirements.txt

# Copy backend code (will be overridden by volume mount in development)
COPY ./backend /app/backend

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app/backend
EXPOSE 8000

# Default command (can be overridden in docker-compose)
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]

# Frontend development stage
FROM node:22-bookworm AS frontend-dev

WORKDIR /app/frontend

# Copy package files first (for caching)
COPY frontend/package*.json ./

# Install dependencies
RUN npm install

# Copy frontend source (will be overridden by volume mount in development)
COPY frontend/ ./

EXPOSE 3000

# Development server with hot reload
CMD ["npm", "run", "dev"]
